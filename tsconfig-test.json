{
  "compilerOptions": {
    "target": "ESNext",
    "skipLibCheck": true,
    "esModuleInterop": true,
    "rootDir": "./src",
    "moduleResolution": "node16",
    "strict": true,
    "module": "Node16",
    "outDir": "./dist-test",
    "resolveJsonModule": true,
    "baseUrl": ".",
    "paths": {
      "@modelcontextprotocol/ext-apps/server": [
        "./node_modules/@modelcontextprotocol/ext-apps/dist/src/server/index.d.ts"
      ]
    }
  },
  "include": ["src/**/*", "package.json"],
  "exclude": ["node_modules", "src/ui"]
}
