{
  "name": "@dynatrace-oss/dynatrace-mcp-server",
  "version": "2.0.1",
  "mcpName": "io.github.dynatrace-oss/Dynatrace-mcp",
  "description": "Model Context Protocol (MCP) server for Dynatrace",
  "keywords": [
    "Dynatrace",
    "mcp",
    "model-context-protocol",
    "server"
  ],
  "main": "./dist/index.js",
  "type": "commonjs",
  "bin": {
    "mcp-server-dynatrace": "dist/index.js"
  },
  "bugs": {
    "url": "https://github.com/dynatrace-oss/dynatrace-mcp/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dynatrace-oss/dynatrace-mcp.git"
  },
  "directories": {
    "dist": "dist"
  },
  "scripts": {
    "prebuild": "npm run typecheck",
    "build": "npm run build:ui",
    "postbuild": "npm run build:server",
    "build:server": "node scripts/build-server.mjs",
    "build:ui": "vite build --config vite.config.mts",
    "typecheck": "tsc --noEmit",
    "mcpb:validate": "npx -y @anthropic-ai/mcpb validate manifest.json",
    "mcpb:pack": "npx -y @anthropic-ai/mcpb pack dist-mcpb/",
    "premcpb:bundle": "npm run build",
    "mcpb:bundle": "npm run mcpb:validate",
    "postmcpb:bundle": "npm run mcpb:pack",
    "prepare": "husky",
    "watch": "node scripts/build-server.mjs --watch",
    "test": "jest",
    "test:unit": "jest --selectProjects unit",
    "test:integration": "jest --selectProjects integration --runInBand",
    "prettier": "prettier --check .",
    "prettier:fix": "prettier --write .",
    "lint": "eslint src",
    "pack": "npm run build && npm pack dist/",
    "release:update-versions": "node scripts/update-versions.js"
  },
  "author": "Dynatrace",
  "license": "MIT",
  "engines": {
    "node": ">=24.0.0"
  },
  "dependencies": {
    "@dynatrace-sdk/client-classic-environment-v2": "6.1.0",
    "@dynatrace-sdk/client-davis-analyzers": "1.10.0",
    "@dynatrace-sdk/client-davis-copilot": "1.0.0",
    "@dynatrace-sdk/client-document": "1.31.0",
    "@dynatrace-sdk/client-platform-management-service": "1.8.0",
    "@dynatrace-sdk/client-query": "1.25.0",
    "@dynatrace-sdk/shared-errors": "1.0.2",
    "@dynatrace/openkit-js": "4.2.0",
    "@dynatrace/strato-components": "3.7.0",
    "@dynatrace/strato-icons": "2.3.0",
    "@modelcontextprotocol/ext-apps": "1.2.2",
    "@modelcontextprotocol/sdk": "1.27.1",
    "@napi-rs/keyring": "1.2.0",
    "commander": "14.0.3",
    "open": "8.4.2",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "undici": "8.1.0",
    "zod": "4.1.13",
    "zod-to-json-schema": "3.25.1"
  },
  "devDependencies": {
    "@commitlint/cli": "20.5.0",
    "@commitlint/config-conventional": "20.5.0",
    "@eslint/js": "9.39.4",
    "@types/jest": "30.0.0",
    "@types/node": "24.13.1",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@typescript-eslint/eslint-plugin": "8.57.1",
    "@typescript-eslint/parser": "8.57.1",
    "@vitejs/plugin-react": "5.2.0",
    "dotenv": "17.3.1",
    "esbuild": "0.27.4",
    "eslint": "10.0.3",
    "husky": "9.1.7",
    "jest": "30.3.0",
    "prettier": "3.8.1",
    "ts-jest": "29.4.6",
    "ts-node": "10.9.2",
    "typescript": "5.7.2",
    "vite": "8.0.16",
    "vite-plugin-singlefile": "2.3.2"
  },
  "overrides": {
    "ajv": "8.18.0",
    "eslint": {
      "ajv": "6.14.0"
    }
  }
}
