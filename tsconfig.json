{
  "compilerOptions": {
    "target": "ESNext",
    "skipLibCheck": true,
    "esModuleInterop": true,
    "rootDir": "./src",
    "moduleResolution": "node16",
    "strict": true,
    "module": "Node16",
    "outDir": "./dist",
    "resolveJsonModule": true,
    "baseUrl": "."
  },
  "include": ["src/**/*", "package.json"],
  "exclude": ["node_modules", "src/ui"]
}
